@using TimeCalculator.Core
<div class="table-responsive mt-3">
    <table class="table table-striped align-middle mb-0">
        <thead>
            <tr>
                <th scope="col">Time</th>
                <th scope="col">Duration</th>
                <th scope="col">Type</th>
                <th scope="col">Description</th>
                <th scope="col" class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var entry in timeCalculator.TimeEntries)
            {
                var isZeroTime = entry.Time.IsZero();

                <tr @key="entry.Id" class="@(isZeroTime ? "tc-zero-time-row" : null)">
                    <td class="@(isZeroTime ? "text-muted" : null)">@entry.Time.ToFormattedString()</td>
                    <td class="@(isZeroTime ? "text-muted" : null)">@entry.Duration.ToFormattedString()</td>
                    <td class="@(isZeroTime ? "text-muted" : null)">@entry.Type</td>
                    <td class="@(isZeroTime ? "text-muted" : null)">@entry.Description</td>
                    <td class="text-end">
                        <button class="btn btn-primary btn-sm" @onclick="() => ReplaceTimeEntry(entry.Id)">
                            Replace
                        </button>
                        <button class="btn btn-danger btn-sm" @onclick="() => RemoveTimeEntry(entry.Id)">
                            Remove
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public TimeCalculatorProgramm timeCalculator { get; set; } = new();

    [Parameter] public EventCallback OnChanged { get; set; }

    private void ReplaceTimeEntry(Guid entryId)
    {
        timeCalculator.ReplaceEntryWithCurrent(entryId);
        _ = NotifyChangedAsync();
    }

    private void RemoveTimeEntry(Guid entryId)
    {
        timeCalculator.RemoveTimeEntry(entryId);
        _ = NotifyChangedAsync();
    }

    private Task NotifyChangedAsync()
    {
        return OnChanged.HasDelegate ? OnChanged.InvokeAsync() : Task.CompletedTask;
    }

}