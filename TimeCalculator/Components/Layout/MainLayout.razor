@inherits LayoutComponentBase
@inject IConsoleLogger ConsoleLogger

<div class="page">
    @* Remove SideBar for now *@
    @* <div class="sidebar">
        <NavMenu />
    </div> *@

    <main>
        <article class="content px-4">
            <ErrorBoundary @ref="_errorBoundary">
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent Context="exception">
                    @{
                        LogException(exception);
                    }
                    <div class="alert alert-danger d-flex flex-column mb-0" style="height: calc(100vh - 2.2rem);" role="alert">
                        <h4 class="alert-heading">Application Error</h4>
                        <p>An unexpected error occurred in the application. Technical details have been logged below & to the browser console.</p>
                        
                        @if (ConsoleLogger.Logs.Any())
                        {
                            <hr>
                            <div class="mt-3 d-flex flex-column flex-grow-1" style="min-height: 0;">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="mb-0">Captured Logs:</h6>
                                    <button class="btn btn-outline-primary btn-sm" onclick="window.copyToClipboard('error-logs', this)">
                                        Copy Logs
                                    </button>
                                </div>
                                <div id="error-logs" class="p-3 bg-dark text-light rounded flex-grow-1" style="overflow-y: auto; font-family: monospace; font-size: 0.85rem; white-space: pre-wrap;">
                                    @foreach (var log in ConsoleLogger.Logs)
                                    {
                                        <div class="mb-2 border-bottom border-secondary pb-1">@log</div>
                                    }
                                </div>
                            </div>
                        }

                        <hr>
                        <div>
                            <button class="btn btn-outline-danger btn-sm" @onclick="Recover">Try to Recover</button>
                        </div>
                    </div>
                </ErrorContent>
            </ErrorBoundary>
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private ErrorBoundary? _errorBoundary;

    protected override void OnParametersSet()
    {
        // Reset the error boundary when navigating
        _errorBoundary?.Recover();
    }

    private void Recover()
    {
        _errorBoundary?.Recover();
    }

    private void LogException(Exception ex)
    {
        _ = ConsoleLogger.LogErrorAsync($"C# Exception: {ex.Message}", ex);
    }
}